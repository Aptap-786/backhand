# ================================================
#   WhatsApp OTP Gateway - Environment Variables
#   Copy this file to .env and fill in the values
# ================================================

# API Key - Use a strong random string (min 32 chars)
API_KEY=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET_KEY

# Server port (Render sets this automatically)
PORT=3000

# WhatsApp session names (comma separated, no spaces)
# Example: personal,work
SESSION_NAMES=personal

# Max OTP history to keep in memory per session
MAX_OTP_HISTORY=50
